{
  "name": "@quidnug/client",
  "version": "1.0.0",
  "description": "Quidnug Client SDK for JavaScript",
  "main": "quidnug-client.js",
  "module": "quidnug-client.js",
  "types": "quidnug-client.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./quidnug-client.js",
      "require": "./quidnug-client.js",
      "types": "./quidnug-client.d.ts",
      "default": "./quidnug-client.js"
    }
  },
  "scripts": {
    "test": "node --test quidnug-client.test.js quidnug-client.retry.test.js",
    "test:watch": "node --test --watch quidnug-client.test.js quidnug-client.retry.test.js",
    "test:retry": "node --test quidnug-client.retry.test.js"
  },
  "files": [
    "quidnug-client.js",
    "quidnug-client.d.ts"
  ],
  "keywords": [
    "quidnug",
    "identity",
    "trust",
    "blockchain",
    "decentralized"
  ],
  "author": "The Quidnug Authors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhmortim/quidnug.git",
    "directory": "clients/js"
  },
  "bugs": {
    "url": "https://github.com/bhmortim/quidnug/issues"
  },
  "homepage": "https://github.com/bhmortim/quidnug#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
