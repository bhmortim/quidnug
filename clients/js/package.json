{
  "name": "@quidnug/client",
  "version": "2.0.0",
  "description": "Quidnug Client SDK for JavaScript \u2014 full protocol surface (QDPs 0001\u20130010)",
  "main": "quidnug-client.js",
  "module": "quidnug-client.js",
  "types": "quidnug-client.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./quidnug-client.js",
      "require": "./quidnug-client.js",
      "types": "./quidnug-client.d.ts",
      "default": "./quidnug-client.js"
    },
    "./v2": {
      "import": "./quidnug-client-v2.js",
      "types": "./quidnug-client-v2.d.ts",
      "default": "./quidnug-client-v2.js"
    },
    "./v1-wire": {
      "import": "./v1-wire.js",
      "default": "./v1-wire.js"
    }
  },
  "scripts": {
    "test": "node --test quidnug-client.test.js quidnug-client.retry.test.js quidnug-client-v2.test.js vectors.test.js",
    "test:watch": "node --test --watch quidnug-client.test.js quidnug-client.retry.test.js quidnug-client-v2.test.js vectors.test.js",
    "test:retry": "node --test quidnug-client.retry.test.js",
    "test:v2": "node --test quidnug-client-v2.test.js",
    "test:vectors": "node --test vectors.test.js"
  },
  "files": [
    "quidnug-client.js",
    "quidnug-client.d.ts",
    "quidnug-client-v2.js",
    "quidnug-client-v2.d.ts",
    "v1-wire.js"
  ],
  "keywords": [
    "quidnug",
    "identity",
    "trust",
    "blockchain",
    "decentralized"
  ],
  "author": "The Quidnug Authors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhmortim/quidnug.git",
    "directory": "clients/js"
  },
  "bugs": {
    "url": "https://github.com/bhmortim/quidnug/issues"
  },
  "homepage": "https://github.com/bhmortim/quidnug#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
