{
  "name": "@quidnug/web-components",
  "version": "2.0.0",
  "description": "Framework-agnostic web components for Quidnug trust-weighted reviews. Drop <quidnug-review> onto any page.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
