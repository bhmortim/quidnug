{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://quidnug.org/schemas/node-advertisement.schema.json",
    "title": "NodeAdvertisementTransaction",
    "description": "Signed declaration by a node quid that publishes where it is reachable, which domains it serves, and what capabilities it offers. See QDP-0014.",
    "type": "object",
    "required": [
        "type",
        "nodeQuid",
        "operatorQuid",
        "endpoints",
        "capabilities",
        "protocolVersion",
        "expiresAt",
        "advertisementNonce",
        "publicKey",
        "signature"
    ],
    "properties": {
        "type":                { "const": "NODE_ADVERTISEMENT" },
        "nodeQuid":            { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        "operatorQuid":        { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        "endpoints": {
            "type": "array",
            "minItems": 1,
            "maxItems": 10,
            "items": {
                "type": "object",
                "required": ["url", "priority", "weight"],
                "properties": {
                    "url": {
                        "type": "string",
                        "format": "uri",
                        "pattern": "^https://"
                    },
                    "protocol": {
                        "type": "string",
                        "enum": ["http/1.1", "http/2", "http/3", "grpc"]
                    },
                    "region": {
                        "type": "string",
                        "maxLength": 64
                    },
                    "priority": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 100
                    },
                    "weight": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 10000
                    }
                },
                "additionalProperties": false
            }
        },
        "supportedDomains": {
            "type": "array",
            "maxItems": 50,
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 253
            }
        },
        "capabilities": {
            "type": "object",
            "properties": {
                "validator":        { "type": "boolean", "default": false },
                "cache":            { "type": "boolean", "default": true },
                "archive":          { "type": "boolean", "default": false },
                "bootstrap":        { "type": "boolean", "default": false },
                "gossipSink":       { "type": "boolean", "default": true },
                "ipfsGateway":      { "type": "boolean", "default": false },
                "maxBodyBytes":     { "type": "integer", "minimum": 0, "maximum": 16777216 },
                "minPeerProtocol":  { "type": "string", "maxLength": 32 }
            },
            "additionalProperties": false
        },
        "protocolVersion": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
            "description": "Semver of the protocol this node speaks"
        },
        "expiresAt": {
            "type": "integer",
            "minimum": 1,
            "description": "UnixNano; rejected at ingress if >7d in the future"
        },
        "advertisementNonce": {
            "type": "integer",
            "minimum": 1,
            "description": "Strictly-monotonic per NodeQuid"
        },
        "publicKey": {
            "type": "string",
            "pattern": "^04[0-9a-f]{128}$",
            "description": "SEC1 uncompressed hex of the node's ECDSA P-256 public key"
        },
        "signature": {
            "type": "string",
            "pattern": "^[0-9a-f]{128}$",
            "description": "Hex-encoded IEEE-1363 r||s signature (64 bytes) over canonical bytes of the tx with signature field cleared"
        }
    },
    "additionalProperties": false
}
